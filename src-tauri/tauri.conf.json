{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "조직 관리",
  "version": "1.0.0",
  "identifier": "com.sunehd564.projectmanger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "조직 관리",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "사업 단위 프로젝트 관리",
    "longDescription": "사업 단위로 할 일·문서·산출물·개발 서버(SSH)를 한 곳에서 관리하는 내부용 데스크톱 앱.",
    "copyright": "© 2026 sundonghwan",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
